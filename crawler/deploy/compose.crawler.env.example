# Example env for compose.crawler.yml (standalone crawler system).
# Copy to .env in this deployment directory before starting:
#   cp compose.crawler.env.example .env
#   docker compose -f compose.crawler.yml up -d

# ===== Application image =====
CRAWLER_IMAGE=codedevin/pod-radar-crawler:v1.0.7

# ===== Docker logs =====
# json-file rotation per container. 50m × 10 = up to about 500M.
DOCKER_LOG_MAX_SIZE=50m
DOCKER_LOG_MAX_FILE=10

# ===== Host port bindings =====
CRAWLER_POSTGRES_HOST_BIND=0.0.0.0
CRAWLER_POSTGRES_HOST_PORT=5545
CRAWLER_API_HOST_BIND=0.0.0.0
CRAWLER_API_PORT=3002
CRAWLER_WEB_HOST_BIND=0.0.0.0
CRAWLER_WEB_PORT=5175
BROWSERLESS_HOST_BIND=0.0.0.0
BROWSERLESS_HOST_PORT=3010
BROWSERLESS_CONCURRENT=3
BROWSERLESS_TIMEOUT=600000

# ===== Docker service credentials =====
CRAWLER_POSTGRES_USER=pod_radar
CRAWLER_POSTGRES_PASSWORD=pod_radar_pass

# ===== Browser-visible crawler URLs =====
# For a standalone crawler domain, leave these empty. Set CRAWLER_ASSET_PREFIX
# only when a reverse proxy or CDN serves Next assets under a subpath.
CRAWLER_ASSET_PREFIX=
CRAWLER_WEB_URL=

# ===== Runtime crawler API and web =====
# compose.crawler.yml overrides database, backend, and browserless inside
# containers. CRAWLER_S3_* is not overridden; it points to external storage.
# Keep host values useful for local CLI commands that read the same root .env.
CRAWLER_HOST=127.0.0.1
CRAWLER_PORT=3002
CRAWLER_WEB_HOST=127.0.0.1
CRAWLER_WEB_PORT=5175
CRAWLER_DATABASE_URL=postgres://pod_radar:pod_radar_pass@127.0.0.1:5545/pod_radar_crawler
CRAWLER_BACKEND_URL=http://127.0.0.1:3002
# CRAWLER_CORS_ORIGINS=http://127.0.0.1:5175

# ===== External crawler S3-compatible object storage =====
# Docker compose does not start MinIO. Create these buckets in your external
# object store before starting workers.
CRAWLER_S3_PROVIDER=s3
CRAWLER_S3_URL_STYLE=virtual-hosted
CRAWLER_S3_ENDPOINT=https://s3.example.com
# Optional. Endpoint for object read/write (uploads, downloads, proxy streams).
# On a same-region cloud host, set this to the provider's internal/VPC endpoint
# (e.g. Aliyun OSS https://oss-<region>-internal.aliyuncs.com) for free, unmetered,
# unthrottled transfer — the public endpoint is capped at the host's public
# bandwidth and large image PUTs time out. Presigned URLs still use the public
# CRAWLER_S3_ENDPOINT above so external browsers can load them. Leave empty off-cloud.
CRAWLER_S3_INTERNAL_ENDPOINT=
CRAWLER_S3_REGION=us-east-1
CRAWLER_S3_ACCESS_KEY_ID=
CRAWLER_S3_SECRET_ACCESS_KEY=
CRAWLER_S3_BUCKET_IMAGES=pod-radar-crawler-images
CRAWLER_S3_BUCKET_DOCS=pod-radar-crawler-docs
CRAWLER_BUCKET_ACCESS=public

# ===== Crawler admin key =====
# Required by the crawler API. Must start with pod-radar_ and be at least 20 chars.
CRAWLER_ADMIN_NAME=admin
CRAWLER_ADMIN_KEY=pod-radar_replace_with_a_long_random_value
# Required in production by shared config. Generate a random value, for example:
#   openssl rand -hex 32
IMAGE_TOKEN_SECRET=replace_with_a_long_random_value
# Symmetric key (AES-256-GCM) encrypting upstream account credentials stored in
# crawler_accounts. Required once you manage/crawl accounts via the accounts API;
# processes that never touch accounts don't need it. Lose it and every stored
# account must be re-entered. Use a long random value.
CRAWLER_CREDENTIAL_SECRET=replace_with_a_long_random_value
# Optional legacy comma-separated fallback admin keys (multi-key deployments).
# CRAWLER_ADMIN_API_KEYS=

# ===== Hihumbird / Flyshark =====
# Env credentials are a fallback; accounts are normally managed via the accounts API.
HIHUMBIRD_USERNAME=
HIHUMBIRD_PASSWORD=
# Upstream API gateway (not the merchant portal); a per-account base_url overrides it.
# HIHUMBIRD_BASE_URL=https://apigw.hihumbird.com
HIHUMBIRD_GROUP_ID=102420649
HIHUMBIRD_APP_ID=2572668
HIHUMBIRD_REL_TYPE=2
HIHUMBIRD_SCENE_ID=1f1o1jf9
HIHUMBIRD_CURSOR_START_AT=2025-05-06T00:00:00+08:00

# ===== Fangguo (方果ERP) — second crawler source =====
# Auth = Bearer accessToken from login + a fixed tenant-id header (no HMAC).
# Credentials are a fallback; accounts are normally managed via the accounts API.
# FANGGUO_TENANT_ID is the INTERNAL tenant id (e.g. 3062076), NOT the UI 系统编号.
FANGGUO_USERNAME=
FANGGUO_PASSWORD=
# FANGGUO_BASE_URL=https://fangguo.com/fgapp
# FANGGUO_TENANT_ID=

# ===== Product-image browser harvest =====
CRAWLER_HARVEST_ENABLED=true
CRAWLER_BROWSERLESS_WS=ws://127.0.0.1:3010
BROWSERLESS_TOKEN=pod-radar-browserless
HIHUMBIRD_FACTORY_SLUG=fnsz-sale
# HIHUMBIRD_FACTORY_LIST_URL=https://flyshark.merchant.hihumbird.com/factory/fnsz-sale/produceManage/produceItemsManage
# HIHUMBIRD_FACTORY_SESSION_JSON=
CRAWLER_HARVEST_RENDER_WAIT_MS=12000
CRAWLER_HARVEST_MAX_PAGES=500
# Idle time with no new images before a harvest page is considered done.
# CRAWLER_HARVEST_QUIET_MS=60000

# ===== Worker tuning =====
# Total hihumbird download parallelism = HIHUMBIRD_FETCHER_REPLICAS × HIHUMBIRD_FETCHER_CONCURRENCY.
# 6 × 8 = 48, matching the PM2 ecosystem (ecosystem.crawler.config.cjs instances: 6).
HIHUMBIRD_FETCHER_REPLICAS=3
HIHUMBIRD_FETCHER_BATCH=8
HIHUMBIRD_FETCHER_CONCURRENCY=8
# Per-container memory cap for the NORMAL hihumbird fetcher; docker reclaims it when
# a leaked/bloated worker tops out (protects the whole host).
HIHUMBIRD_FETCHER_MEM_LIMIT=1500m
# Max claim attempts for the NORMAL fetcher. A 272MP-class source image OOM-crashes
# the normal fetcher; after this many attempts it stops claiming that row so the
# high-memory fetcher (max-attempts 5) takes over. Keep low.
HIHUMBIRD_FETCHER_MAX_ATTEMPTS=2
# Dedicated high-memory hihumbird fetcher (single instance): picks up oversized images
# the normal fetcher crashed on (attempts 2..4) and helps with normal images otherwise.
# 4096m (~2.7× normal) holds a big image's full sharp decode (~1GB+). Low concurrency
# so multiple big images don't fill 4G at once. attempts>=5 are reaped as failed.
HIHUMBIRD_FETCHER_HIGHMEM_LIMIT=4096m
HIHUMBIRD_HIGHMEM_BATCH=4
HIHUMBIRD_HIGHMEM_CONCURRENCY=2
# Fangguo (方果ERP) fetcher: assets/labels are public direct links (no headless
# harvest), so the source only needs sync + fetcher. Total parallelism = REPLICAS ×
# CONCURRENCY. MEM_LIMIT mirrors the normal hihumbird fetcher.
FANGGUO_FETCHER_REPLICAS=2
FANGGUO_FETCHER_BATCH=8
FANGGUO_FETCHER_CONCURRENCY=8
FANGGUO_FETCHER_MEM_LIMIT=1500m
# Decoded image pixel limit for hihumbird assets. false disables sharp's
# default 268402689-pixel guard for trusted print/source images.
CRAWLER_IMAGE_PROCESS_PIXEL_LIMIT=false
# Orders older than this many days (item create time) crawl only production +
# source images; product images (harvest) and labels are skipped. Forward-only.
CRAWLER_HISTORY_ORDER_DAYS=90

# Set this to /app/logs/harvest-shots to save screenshots from inside the container.
DOCKER_CRAWLER_HARVEST_SCREENSHOT_DIR=
