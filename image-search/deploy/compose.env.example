# Example env for compose.yml (main image-search system).
# Copy to .env in this deployment directory before starting:
#   cp compose.env.example .env
#   docker compose -f compose.yml up -d

# ===== Application image =====
MAIN_IMAGE=codedevin/pod-radar-main:v1.0.0

# ===== Docker logs =====
# json-file rotation per container. 50m × 10 = up to about 500M.
DOCKER_LOG_MAX_SIZE=50m
DOCKER_LOG_MAX_FILE=10

# ===== Host port bindings =====
POSTGRES_HOST_BIND=0.0.0.0
POSTGRES_HOST_PORT=5544
BACKEND_HOST_BIND=0.0.0.0
BACKEND_PORT=3001
WEB_HOST_BIND=0.0.0.0
WEB_PORT=5174

# ===== Docker service credentials =====
POSTGRES_USER=pod_radar
POSTGRES_PASSWORD=pod_radar_pass

# ===== Runtime database =====
# compose.yml overrides this inside containers to pgvector:5432. Keep this
# value useful for local CLI commands that read the same root .env.
DATABASE_URL=postgres://pod_radar:pod_radar_pass@127.0.0.1:5544/pod_radar

# ===== External S3-compatible object storage =====
# Docker compose does not start MinIO. Create these buckets in your external
# object store before starting workers.
S3_PROVIDER=s3
S3_URL_STYLE=virtual-hosted
S3_ENDPOINT=https://s3.example.com
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_IMAGES=pod-radar-images
S3_BUCKET_THUMBS=pod-radar-thumbs
S3_BUCKET_DOCS=pod-radar-docs
S3_BUCKET_ACCESS=public

# ===== Bootstrap admin key =====
# Must start with pod-radar_ and be at least 20 chars.
BOOTSTRAP_NAME=admin
BOOTSTRAP_ADMIN_KEY=pod-radar_replace_with_a_long_random_value

# ===== Web and search =====
# Optional browser-visible crawler-web target shown from the main UI.
# Use /crawler when a reverse proxy routes the same domain to crawler-web, or
# an absolute URL such as https://example.com/crawler when it is separate.
NEXT_PUBLIC_CRAWLER_WEB_URL=
CRAWLER_WEB_URL=
NEXT_PUBLIC_SEARCH_MIN_SCORE=0.5
SEARCH_MIN_SCORE=0.5
SEARCH_DUPLICATE_REVIEW_ENABLED=true
SEARCH_DUPLICATE_REVIEW_SCORE=0.98
IMAGE_TOKEN_TTL=900
# IMAGE_TOKEN_SECRET=replace_with_a_long_random_value

# ===== Worker tuning =====
# Total main image fetch parallelism = MAIN_FETCHER_REPLICAS × MAIN_FETCHER_CONCURRENCY.
MAIN_FETCHER_REPLICAS=1
MAIN_FETCHER_BATCH=8
MAIN_FETCHER_CONCURRENCY=8
MAIN_EMBED_REPLICAS=1
MAIN_EMBED_BATCH=8
MAIN_EMBED_CONCURRENCY=4
MAIN_SEARCH_REPLICAS=1
MAIN_SEARCH_BATCH=4
MAIN_SEARCH_CONCURRENCY=4

# ===== Embedding provider =====
# Set EMBEDDING_API_KEY before using embedding/search features. Set
# EMBEDDING_ENABLED=false to keep the embed worker idle during local bring-up.
EMBEDDING_ENABLED=true
EMBEDDING_PROVIDER=dashscope
EMBEDDING_MODEL=qwen3-vl-embedding
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/multimodal-embedding/multimodal-embedding
EMBEDDING_DIMENSION=2560
EMBEDDING_TIMEOUT=10
EMBEDDING_API_KEY=
# EMBEDDING_SLUG=dashscope_qwen3_vl_embedding
